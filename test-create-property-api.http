### Test Create Property API - Using IDs (all existing data)
POST http://localhost:3000/properties
Content-Type: application/json
Authorization: Bearer your-jwt-token-here

{
  "listingTypeId": "listing-type-uuid-here",
  "categoryId": "category-uuid-here",
  "propertyTypeId": "property-type-uuid-here",
  "bathrooms": 2,
  "builtUpAreaSqFt": 1200.50,
  "carpetAreaSqFt": 1000.00,
  "ageOfProperty": 5,
  "userId": "user-uuid-here",
  "customBhk": null,
  "status": "draft",
  "city": {
    "id": "city-uuid-here"
  },
  "society": {
    "id": "society-uuid-here"
  },
  "locality": {
    "id": "locality-uuid-here"
  },
  "bhkType": {
    "id": "bhk-type-uuid-here"
  },
  "builtUpArea": {
    "id": "built-up-area-uuid-here"
  }
}

### Test Create Property API - Using Names (create new master data)
POST http://localhost:3000/properties
Content-Type: application/json
Authorization: Bearer your-jwt-token-here

{
  "listingTypeId": "listing-type-uuid-here",
  "categoryId": "category-uuid-here",
  "propertyTypeId": "property-type-uuid-here",
  "bathrooms": 3,
  "builtUpAreaSqFt": 1500.75,
  "carpetAreaSqFt": 1200.00,
  "ageOfProperty": 3,
  "userId": "user-uuid-here",
  "customBhk": null,
  "status": "active",
  "city": {
    "name": "New Delhi",
    "state": "Delhi",
    "latitude": 28.6139,
    "longitude": 77.2090
  },
  "society": {
    "name": "Green Park Residency",
    "address": "123 Green Park, New Delhi",
    "pincode": "110016",
    "latitude": 28.6140,
    "longitude": 77.2091
  },
  "locality": {
    "name": "Green Park",
    "sector": "Sector 15",
    "latitude": 28.6141,
    "longitude": 77.2092
  },
  "bhkType": {
    "name": "3 BHK",
    "code": "3bhk",
    "sortOrder": 3
  },
  "builtUpArea": {
    "superBuiltUpArea": 1500.75,
    "carpetArea": 1200.00,
    "noOfBathrooms": 3
  }
}

